# ─────────────────────────────────────────────────────────────────────────────
# Acclimation Sports Management — Environment Variables Template
# Copy this file to backend/.env and fill in real values.
# NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production          # production | development
IP_ADDRESS=0.0.0.0           # 0.0.0.0 for Docker; localhost for bare-metal dev

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# In production this is your public domain (handled by Nginx)
CORS_ORIGIN=http://localhost:3000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_64_byte_random_hex
JWT_EXPIRE_IN=1d
JWT_REFRESH_SECRET=change_me_to_another_64_byte_random_hex
JWT_REFRESH_EXPIRE_IN=365d

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_FROM=Acclimation Sports <you@gmail.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_gmail_app_password   # https://myaccount.google.com/apppasswords

# ── Super Admin (seeded on first startup) ────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=StrongPassword123!

# ── Frontend (baked into Next.js build) ──────────────────────────────────────
# In Docker: http://localhost/api  (through Nginx on same host)
# In local dev: http://localhost:5001
NEXT_PUBLIC_API_URL=http://localhost/api
